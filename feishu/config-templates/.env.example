# ============================================================
# Hermes Feishu Bot-to-Bot 配置模板
# ============================================================
# 复制此文件为 .env，替换 <> 中的值为你的实际配置。
# 两个 Bot 实例各用一份，App ID / Secret / Open ID 不同。

# ---- 飞书应用凭证 ----
FEISHU_APP_ID=<your_app_id>              # cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=<your_app_secret>      # 32 字符密钥
FEISHU_ENCRYPT_KEY=<your_encrypt_key>    # 可选，事件加密密钥
FEISHU_VERIFICATION_TOKEN=<your_token>   # 事件订阅验证 token

# ---- Bot 身份（关键！） ----
# 不设置会导致自回环或无法区分对端 Bot。
# 获取方法：GET /open-apis/bot/v3/info → open_id 字段
FEISHU_BOT_OPEN_ID=<your_bot_open_id>    # ou_xxxxxxxxxxxxxxxx

# ---- Bot-to-Bot 通信 ----
# none   = 忽略所有 Bot 消息（默认，单 Bot 用）
# mentions = 只处理 @ 自己的 Bot 消息（推荐）
# all    = 接受所有 Bot 消息（慎用）
FEISHU_ALLOW_BOTS=mentions

# ---- LLM 提供商 ----
OPENAI_API_KEY=<your_api_key>
OPENAI_MODEL=gpt-4o

# ---- 可选：高级配置 ----
# FEISHU_BOT_USER_ID=<your_user_id>      # 仅 sender_id_type=user_id 时需要
# FEISHU_APP_TYPE=custom                  # custom | store
